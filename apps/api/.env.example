# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed browser origins (the Vite dev server, prod web app)
CORS_ORIGINS=http://localhost:5173

# ─── Database ─────────────────────────────────────────────
# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://assetflow:assetflow@localhost:5432/assetflow?schema=public

# ─── Auth / JWT ───────────────────────────────────────────
# Use long, random, DISTINCT secrets. Generate with: openssl rand -hex 48
JWT_ACCESS_SECRET=replace-with-64-char-random-hex
JWT_REFRESH_SECRET=replace-with-a-DIFFERENT-64-char-random-hex

# ─── Mail (Phase 2 forgot-password) ───────────────────────
MAIL_FROM="AssetFlow <no-reply@assetflow.local>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ─── App URLs ─────────────────────────────────────────────
WEB_APP_URL=http://localhost:5173
